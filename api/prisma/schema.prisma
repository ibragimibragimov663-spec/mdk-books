generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ПОЛЬЗОВАТЕЛИ ─────────────────────────────────────────────────────────────

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String?   @unique
  login        String?   @unique
  passwordHash String?
  role         Role      @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  refreshTokens RefreshToken[]
}

enum Role {
  ADMIN
}

// ─── ТОКЕНЫ ───────────────────────────────────────────────────────────────────

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── АВТОРЫ ───────────────────────────────────────────────────────────────────

model Author {
  id    Int    @id @default(autoincrement())
  name  String
  books Book[]
}

// ─── КАТЕГОРИИ ────────────────────────────────────────────────────────────────

model Category {
  id    Int    @id @default(autoincrement())
  slug  String @unique
  name  String
  order Int    @default(0)
  books Book[]
}

// ─── КНИГИ ────────────────────────────────────────────────────────────────────

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  authorId    Int
  author      Author   @relation(fields: [authorId], references: [id])
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  description String?
  price       Int
  oldPrice    Int?
  cover       String?
  isbn        String?  @unique
  publisher   String?
  year        Int?
  pages       Int?
  available   Boolean  @default(true)
  isNew       Boolean  @default(false)
  isPopular   Boolean  @default(false)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]
}

// ─── ЗАКАЗЫ ───────────────────────────────────────────────────────────────────

model Order {
  id        Int         @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  comment   String?
  status    OrderStatus @default(NEW)
  total     Int
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  items OrderItem[]
}

model OrderItem {
  id      Int   @id @default(autoincrement())
  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  bookId  Int
  book    Book  @relation(fields: [bookId], references: [id])
  qty     Int
  price   Int
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── БАННЕРЫ ──────────────────────────────────────────────────────────────────
// Только изображение — весь контент внутри самой картинки

model Banner {
  id        Int      @id @default(autoincrement())
  image     String
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
